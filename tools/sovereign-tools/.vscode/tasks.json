{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Sovereign Assembly",
      "type": "shell",
      "command": "${workspaceFolder}/software/vm/spu_vm",
      "args": ["${file}"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Run with --proof",
      "type": "shell",
      "command": "${workspaceFolder}/software/vm/spu_vm",
      "args": ["${file}", "--proof"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    }
  ]
}
