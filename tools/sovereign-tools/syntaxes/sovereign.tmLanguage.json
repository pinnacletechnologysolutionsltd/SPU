{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sovereign Assembly",
  "scopeName": "source.sovereign-asm",
  "comment": "SPU-13 Sovereign Engine — TextMate grammar for .sas / .lam files",
  "patterns": [
    { "include": "#comments" },
    { "include": "#labels" },
    { "include": "#flow-opcodes" },
    { "include": "#quadray-opcodes" },
    { "include": "#arithmetic-opcodes" },
    { "include": "#quadray-registers" },
    { "include": "#scalar-registers" },
    { "include": "#hex-literals" },
    { "include": "#decimal-literals" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.semicolon.sovereign",
      "match": ";.*$"
    },
    "labels": {
      "name": "entity.name.label.sovereign",
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:"
    },
    "flow-opcodes": {
      "name": "keyword.control.flow.sovereign",
      "match": "(?i)\\b(JMP|SNAP|COND|CALL|RET|NOP)\\b"
    },
    "quadray-opcodes": {
      "name": "keyword.other.quadray.sovereign",
      "match": "(?i)\\b(QLOAD|QADD|QROT|QNORM|QLOG|SPREAD|HEX|EQUIL|IDNT|JINV|ANNE)\\b"
    },
    "arithmetic-opcodes": {
      "name": "keyword.operator.arithmetic.sovereign",
      "match": "(?i)\\b(LD|ADD|SUB|MUL|ROT|LOG)\\b"
    },
    "quadray-registers": {
      "name": "variable.other.quadray-register.sovereign",
      "match": "\\bQR([0-9]|1[0-2])\\b"
    },
    "scalar-registers": {
      "name": "variable.other.register.sovereign",
      "match": "\\bR([0-9]|1[0-9]|2[0-5])\\b"
    },
    "hex-literals": {
      "name": "constant.numeric.hex.sovereign",
      "match": "\\b0x[0-9A-Fa-f]+\\b"
    },
    "decimal-literals": {
      "name": "constant.numeric.decimal.sovereign",
      "match": "\\b-?[0-9]+\\b"
    }
  }
}
