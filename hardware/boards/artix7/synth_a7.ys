# synth_a7.ys — SPU-13 Artix-7 Yosys Synthesis Script
#
# Usage:
#   yosys synth_a7.ys
#
# Set DEVICE and ENABLE_* via command line:
#   yosys -p 'chparam -set DEVICE A7_35T spu_a7_top' synth_a7.ys

read_verilog -I hardware/rtl/arch \
    hardware/boards/artix7/spu_a7_top.v \
    hardware/rtl/core/spu13/spu13_core.v \
    hardware/rtl/core/spu13/spu13_lattice.v \
    hardware/rtl/core/spu13/laminar_node.v \
    hardware/rtl/core/shared/spu_rotor_vault.v \
    hardware/rtl/core/shared/spu_cross_rotor.v \
    hardware/rtl/core/shared/davis_gate_dsp.v \
    hardware/rtl/core/shared/spu_quadray_permute.v \
    hardware/rtl/core/shared/spu_quadray_regfile.v \
    hardware/rtl/core/spu13/spu13_rotor_core_tdm.v \
    hardware/rtl/common/prim/surd_multiplier.v \
    hardware/rtl/common/prim/spu_gowin_prim.v \
    hardware/rtl/common/prim/gowin_mult18.v \
    hardware/rtl/core/spu13/spu_sequencer.v \
    hardware/rtl/core/spu13/spu_quadrance_accum.v \
    hardware/rtl/core/spu13/spu_som_bmu.v \
    hardware/rtl/core/spu13/spu_cluster_reduce.v \
    hardware/rtl/core/spu13/spu13_axiomatic_gatekeeper.v \
    hardware/rtl/top/spu_ve_qr_init.v \
    hardware/rtl/peripherals/io/spu_spi_slave.v \
    hardware/rtl/peripherals/io/spu_uart_tx.v \
    hardware/rtl/arch/spu_bio_stubs.v

# Full stack by default; override for smaller targets
chparam -set DEVICE         "A7_100T" \
        -set ENABLE_MATH    1 \
        -set ENABLE_SOM     1 \
        -set ENABLE_GATEKEEPER 1 \
        -set ENABLE_GPU     0 \
        -set ENABLE_RPLU    0 \
        -set ENABLE_LATTICE 0 \
        -set ENABLE_SDRAM   0 \
        spu_a7_top

hierarchy -check -top spu_a7_top

# Xilinx 7-series synthesis
synth_xilinx -family artix7 -top spu_a7_top -json build/spu_a7.json

write_json build/spu_a7.json
