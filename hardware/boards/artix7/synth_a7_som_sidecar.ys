# Complete writable SOM-SIDECAR for Wukong Artix-7.
# The functional top below is the exact Tang-silicon-proven implementation;
# spu_a7_som_sidecar_top.v only adapts its board ports.

read_verilog -lib +/xilinx/cells_sim.v

read_verilog -I hardware/rtl/arch \
    hardware/boards/artix7/spu_a7_som_sidecar_top.v \
    hardware/boards/tang_primer_25k/spu13_tang25k_som_sidecar_top.v \
    hardware/rtl/peripherals/io/spu_spi_cfg.v \
    hardware/rtl/core/spu13/spu13_som1_frame.v \
    hardware/rtl/core/spu13/spu_som_weight_bram.v \
    hardware/rtl/core/spu13/spu_som_bmu.v \
    hardware/rtl/core/spu13/spu_cluster_reduce.v

hierarchy -check -top spu_a7_som_sidecar_top
