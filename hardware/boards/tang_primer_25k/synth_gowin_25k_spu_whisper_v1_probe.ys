# synth_gowin_25k_spu_whisper_v1_probe.ys
# Whisper v1 emitter+listener loopback probe for Tang Primer 25K.
# Verified in testbench (hardware/tests/peripherals/spu_whisper_v1_tb.v).

read_verilog -lib +/gowin/cells_xtra_gw5a.v

read_verilog -I hardware/rtl/arch \
    hardware/rtl/peripherals/whisper/spu_uart_tx.v \
    hardware/rtl/peripherals/whisper/spu_uart_rx.v \
    hardware/rtl/peripherals/whisper/spu_whisper_v1_emitter.v \
    hardware/rtl/peripherals/whisper/spu_whisper_v1_listener.v \
    hardware/boards/tang_primer_25k/spu_tang25k_whisper_v1_probe.v

hierarchy -top spu_tang25k_whisper_v1_probe

synth_gowin -family gw5a -top spu_tang25k_whisper_v1_probe \
    -json build/tang_primer_25k_whisper_v1_probe.json -run begin:map_cells
techmap -map +/gowin/cells_map.v
opt_lut_ins -tech gowin
hilomap -singleton -hicell VCC V -locell GND G
clean
hierarchy -check
check -noinit
blackbox =A:whitebox
write_json build/tang_primer_25k_whisper_v1_probe.json
