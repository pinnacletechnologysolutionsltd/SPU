read_verilog -I hardware/rtl/arch \
    hardware/boards/tang_primer_25k/spu_tang25k_sdram_min_probe_dq10_masked.v \
    hardware/rtl/peripherals/storage/spu_mem_bridge_sdram.v

chparam -set SDRAM_COL_BITS 9 \
        -set SDRAM_ROW_BITS 13 \
        -set SDRAM_RANK_BITS 1 \
        -set SDRAM_XSDS_INVERTED_RANK_CS 1 \
        -set SDRAM_REFRESH_CYCLES 49 \
        spu_tang25k_sdram_min_probe_dq10_masked

hierarchy -check -top spu_tang25k_sdram_min_probe_dq10_masked

synth_gowin -family gw5a -top spu_tang25k_sdram_min_probe_dq10_masked -json build/sdram_min_probe_mask.json
write_json build/sdram_min_probe_mask.json
