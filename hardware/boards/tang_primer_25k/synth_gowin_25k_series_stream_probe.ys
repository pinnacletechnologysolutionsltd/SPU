# synth_gowin_25k_series_stream_probe.ys — series-stream silicon probe.
# One shared M31 multiplier muxed between the Fp4 tower and the stream;
# golden vectors from the committed .mem as a BRAM-initialized ROM.

read_verilog -lib +/gowin/cells_xtra_gw5a.v

read_verilog -I hardware/rtl/arch \
    hardware/boards/tang_primer_25k/spu13_tang25k_series_stream_probe.v \
    hardware/rtl/core/spu13/spu13_series_stream.v \
    hardware/rtl/core/spu13/spu13_fp4_inverter.v \
    hardware/rtl/core/spu13/spu13_m31_multiplier.v

hierarchy -top spu13_tang25k_series_stream_probe

synth_gowin -family gw5a -top spu13_tang25k_series_stream_probe \
    -json build/series_stream_probe.json -run begin:map_cells
techmap -map +/gowin/cells_map.v
opt_lut_ins -tech gowin
hilomap -singleton -hicell VCC V -locell GND G
clean
hierarchy -check
check -noinit
blackbox =A:whitebox
write_json build/series_stream_probe.json
