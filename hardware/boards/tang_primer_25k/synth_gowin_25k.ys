# synth_gowin_25k.ys — Yosys synthesis for Tang Primer 25K (GW5A-LV25MG121)
#
# Open-source flow:  yosys  →  nextpnr-gowin  →  gowin_pack
#
# Usage (resource count only):
#   yosys hardware/boards/tang_primer_25k/synth_gowin_25k.ys
#
# Full open-source PAR + bitstream:
#   yosys  hardware/boards/tang_primer_25k/synth_gowin_25k.ys
#   nextpnr-himbaechel --device GW5A-LV25MG121NES \
#                 --json tang_primer_25k.json \
#                 -o cst=hardware/boards/tang_primer_25k/tang_primer_25k.cst \
#                 --write tang_primer_25k_pnr.json
#   gowin_pack tang_primer_25k_pnr.json -o tang_primer_25k.fs
#   openFPGALoader -b tang_primer_25k tang_primer_25k.fs
#
# GOWIN EDA (free, requires registration) recommended on Linux/Windows for
# timing closure on GW5A: https://www.gowinsemi.com/en/support/download_eda/
# CC0 1.0 Universal.

# ─── rPLL blackbox (GW5A primitive, inserted by P&R tool) ─────────────────
# rPLL declared as blackbox stub in pll_gowin_stub.v
read_verilog hardware/boards/tang_primer_25k/pll_gowin_stub.v
read_verilog hardware/boards/tang_primer_25k/gowin_sp_stub.v

# ─── Architecture defines ─────────────────────────────────────────────────
read_verilog -sv -I hardware/common/rtl hardware/common/rtl/spu_arch_defines.vh

# ─── Primitives ────────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/gowin_mult18.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_multiplier_serial.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_psram_ctrl.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_smul_tdm.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/surd_multiplier.v

# ─── Core RTL ──────────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/common/rtl/spu_cross_rotor.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/davis_gate_dsp.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_sequencer.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_rotor_vault.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_unified_alu_tdm.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_core.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/rational_surd5_scale_manager.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_lattice.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/laminar_node.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/rational_surd5_add.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/rational_surd5_mul.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/rational_surd5_mul64.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/rational_surd5_norm.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_rotor_core.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_scoreboard.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu1_alu.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_command_processor.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_core.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_execution_unit.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_folded_alu.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_identity_monad.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_light_core.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_nano_core.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_tensegrity_balancer.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/toroidal_regfile.v

# ─── SPU-4 Sentinel ────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_decoder.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu_4_euclidean_alu.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_regfile.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_core.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_top.v

# ─── SPU-13 sub-modules ────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/spu13/rtl/spu_berry_gate.v
read_verilog -I hardware/common/rtl hardware/spu13/rtl/spu_janus_mirror.v
read_verilog -I hardware/common/rtl hardware/spu13/rtl/spu_permute_13.v
read_verilog -I hardware/common/rtl hardware/spu13/rtl/spu_13_top.v

# ─── System infrastructure ─────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/common/rtl/top/spu_sierpinski_clk.v
read_verilog -I hardware/common/rtl hardware/common/rtl/spu_soft_start.v
read_verilog -I hardware/common/rtl hardware/common/rtl/top/spu_laminar_power.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/SPU_ARTERY_FIFO.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/SPU_WHISPER_TX.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/spu_spi_slave.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/sd_card_master.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/sd_bram_loader_dp.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/uart_debug_tx.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/boot_ram_dp.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/sd_bram_loader.v
# IO bridge and UART/surd transmitter used for MCU–FPGA telemetry and control
read_verilog -I hardware/common/rtl hardware/common/rtl/include/auto_stubs.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/surd_uart_tx.v
read_verilog -I hardware/common/rtl hardware/common/rtl/io/spu_io_bridge.v
read_verilog -I hardware/common/rtl hardware/common/rtl/top/spu_system.v

# ─── Memory bridges ────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/common/rtl/mem/spu_mem_bridge_sdram.v
read_verilog -I hardware/common/rtl hardware/common/rtl/mem/spu_sdram_arbiter.v
read_verilog -I hardware/common/rtl hardware/common/rtl/mem/spu_mem_bridge_qspi.v

# Bio sensors
read_verilog -I hardware/common/rtl hardware/common/rtl/bio/spu_metabolic_sense.v
read_verilog -I hardware/common/rtl hardware/common/rtl/bio/spu_viscosity_monitor.v

# ─── GPU / HAL ─────────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_video_timing.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/rational_sine_provider.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/rational_sine_rom.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/rational_sine_rom_q32.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/rplu_bram_wrapper.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu4_bram_ip.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_edge_stepper.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_raster_unit.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_dual_raster.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_bresenham_raster.v
read_verilog -I hardware/common/rtl hardware/common/rtl/gpu/spu_gpu_top.v
read_verilog -I hardware/common/rtl hardware/common/rtl/hal/HAL_VGA.v
read_verilog -I hardware/common/rtl hardware/common/rtl/hal/HAL_HDMI_TMDS.v
read_verilog -I hardware/common/rtl hardware/common/rtl/hal/HAL_HDMI.v

# ─── Board top ─────────────────────────────────────────────────────────────
read_verilog -I hardware/common/rtl hardware/boards/tang_primer_25k/spu_tang_top.v

# ─── Synthesis ─────────────────────────────────────────────────────────────
hierarchy -check -top spu_tang_top
synth_gowin -family gw5a -top spu_tang_top -json build/tang_primer_25k.json
stat
