// tang_primer_25k.cst — Physical Constraints for Tang Primer 25K
// Device:  GW5A-LV25MG121NES  (GW5A-25A, 121-ball BGA in the OSS flow)
// Crystal: 50 MHz at E2
//
// Pin sources (cross-referenced against three official Sipeed CSTs):
//   nestang-25k/src/nestang.cst          (GW5A-LV25MG121NES)
//   ZiyangYE/LicheeTang25k_SDRAM         (reference only; different package code)
//   sipeed/TangPrimer-25K-example pmod_led.cst
//
// sdram_cke is NOT exposed here — it is hardwired to VCC on the board.
// (Absent from every official Sipeed CST; spu_mem_bridge_sdram drives it 1'b1.)
//
// PMOD J4 bottom row is used for the first-stage SPI flash bring-up probe.
//
// CC0 1.0 Universal.

// ─── System clock (50 MHz crystal) ──────────────────────────────────────
IO_LOC  "sys_clk"        E2;
IO_PORT "sys_clk"        IO_TYPE=LVCMOS33 PULL_MODE=NONE;

// ─── User LEDs (active-low, 3 on-board) ──────────────────────────────────
IO_LOC  "led[0]"         L6;
IO_LOC  "led[1]"         E8;
IO_LOC  "led[2]"         D7;
IO_PORT "led[0]"         IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[1]"         IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led[2]"         IO_TYPE=LVCMOS33 DRIVE=8;

// ─── 40-pin SDRAM module (Tang_sdram_xsds v1.3, dual W9825G6KH-6) ───────
// sdram_cke is hardwired on the module/header — no FPGA pin assignment needed.
// The v1.3 X2 module exposes one CS input on K9; the second chip is selected
// through the module's inverter, so the RTL treats sdram_cs_n as rank select.
IO_LOC  "sdram_clk"      E3;
IO_PORT "sdram_clk"      IO_TYPE=LVCMOS33 DRIVE=16;

IO_LOC  "sdram_cs_n"     K9;
IO_PORT "sdram_cs_n"     IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_ras_n"    L10;
IO_PORT "sdram_ras_n"    IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_cas_n"    K10;
IO_PORT "sdram_cas_n"    IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_we_n"     J7;
IO_PORT "sdram_we_n"     IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_ba[0]"    L9;
IO_LOC  "sdram_ba[1]"    K8;
IO_PORT "sdram_ba[0]"    IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_ba[1]"    IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_a0"  F6;
IO_LOC  "sdram_a1"  F7;
IO_LOC  "sdram_a2"  J10;
IO_LOC  "sdram_a3"  J11;
IO_LOC  "sdram_a4"  K7;
IO_LOC  "sdram_a5"  H2;
IO_LOC  "sdram_a6"  H1;
IO_LOC  "sdram_a7"  H4;
IO_LOC  "sdram_a8"  G4;
IO_LOC  "sdram_a9"  J2;
IO_LOC  "sdram_a10" J8;
IO_LOC  "sdram_a11" J1;
IO_LOC  "sdram_a12" D1;
IO_PORT "sdram_a0"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a1"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a2"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a3"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a4"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a5"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a6"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a7"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a8"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a9"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a10" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a11" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_a12" IO_TYPE=LVCMOS33 DRIVE=8;


IO_LOC  "sdram_dq[0]"   K2;
IO_LOC  "sdram_dq[1]"   K1;
IO_LOC  "sdram_dq[2]"   L1;
IO_LOC  "sdram_dq[3]"   L2;
IO_LOC  "sdram_dq[4]"   K4;
IO_LOC  "sdram_dq[5]"   J4;
IO_LOC  "sdram_dq[6]"   G1;
IO_LOC  "sdram_dq[7]"   G2;
IO_LOC  "sdram_dq[8]"   L3;
IO_LOC  "sdram_dq[9]"   L4;
IO_LOC  "sdram_dq[10]"  B2;
IO_LOC  "sdram_dq[11]"  C2;
IO_LOC  "sdram_dq[12]"  F2;
IO_LOC  "sdram_dq[13]"  F1;
IO_LOC  "sdram_dq[14]"  E1;
IO_LOC  "sdram_dq[15]"  A1;
IO_PORT "sdram_dq[0]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[1]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[2]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[3]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[4]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[5]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[6]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[7]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[8]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[9]"   IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[10]"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[11]"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[12]"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[13]"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[14]"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dq[15]"  IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "sdram_dm[0]"    L8;
IO_LOC  "sdram_dm[1]"    L7;
IO_PORT "sdram_dm[0]"    IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "sdram_dm[1]"    IO_TYPE=LVCMOS33 DRIVE=8;

// ─── Dual UART Bridge (Host & Telemetry) ──────────────────────────────────
IO_LOC  "periph_rx"          B3;    // Input from RP2350 (USB-A)
IO_LOC  "uart_tx_telemetry"  B11;   // Output to BL616 (USB-C)
IO_LOC  "uart_rx_telemetry"  A11;   // Input from BL616 (USB-C)
IO_PORT "periph_rx"          IO_TYPE=LVCMOS33 PULL_MODE=UP;
IO_PORT "uart_tx_telemetry"  IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "uart_rx_telemetry"  IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC  "uart_tx"            C3;    // Host-bound TX
IO_PORT "uart_tx"            IO_TYPE=LVCMOS33 DRIVE=8;

// ─── SPI southbridge (PMOD J4 pins, to RP2350-Zero header) ───────────────
// Proven J4 flash-compatible mapping:
//   G10 = CS#, D10 = SCK, B10 = MOSI/D1, C10 = MISO/DO.
IO_LOC  "spi_cs_n"       G10;
IO_LOC  "spi_sck"        D10;
IO_LOC  "spi_mosi"       B10;
IO_LOC  "spi_miso"       C10;
IO_PORT "spi_cs_n"       IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "spi_sck"        IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "spi_mosi"       IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "spi_miso"       IO_TYPE=LVCMOS33 PULL_MODE=UP;

// ─── I2S Audio Interface (Free GPIO) ──────────────────────────────────────
// i2s_lrclk, i2s_bclk, i2s_dout disabled to avoid PnR pin errors.
// IO_LOC  "i2s_lrclk"      A6;
// IO_LOC  "i2s_bclk"       A7;
// IO_LOC  "i2s_dout"       A8;
// IO_PORT "i2s_lrclk"      IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "i2s_bclk"       IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "i2s_dout"       IO_TYPE=LVCMOS33 DRIVE=8;

// PMOD JA: general purpose 8-bit header (pmod_ja_out[7:0]) — mapped to A2..A9
// NOTE: PMOD JA pins omitted from constraints to avoid referencing package pins
// not present in the active OSS target package during PnR.
// The original mappings are preserved below as comments for reference:
// IO_LOC  "pmod_ja_out[0]" A2;
// IO_LOC  "pmod_ja_out[1]" A3;
// IO_LOC  "pmod_ja_out[2]" A4;
// IO_LOC  "pmod_ja_out[3]" A5;
// IO_LOC  "pmod_ja_out[4]" A6;
// IO_LOC  "pmod_ja_out[5]" A7;
// IO_LOC  "pmod_ja_out[6]" A8;
// IO_LOC  "pmod_ja_out[7]" A9;
// IO_PORT "pmod_ja_out[0]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[1]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[2]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[3]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[4]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[5]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[6]" IO_TYPE=LVCMOS33 DRIVE=8;
// IO_PORT "pmod_ja_out[7]" IO_TYPE=LVCMOS33 DRIVE=8;
