# synth_gowin_25k_spu13_irotc_spi.ys — IROTC southbridge spin
# Lean IROTC spin: MATH=0 (no TDM rotor/Davis DSP — the fat path that no
# longer fits at HEAD), CORE_ENABLE_IROTC=1. A5 rotations via SPI 0xB1
# instruction path, results via 0xAE. Do not issue ROTC on this spin.

read_verilog -lib +/gowin/cells_xtra_gw5a.v

read_verilog -I hardware/rtl/arch \
    hardware/boards/tang_primer_25k/spu13_tang25k_fpga_top.v \
    hardware/rtl/peripherals/io/spu_spi_slave.v \
    hardware/rtl/core/shared/spu_isa_decoder.v \
    hardware/rtl/core/shared/spu_twin_regfile.v \
    hardware/rtl/core/shared/spu_rau.v \
    hardware/rtl/core/shared/spu_pipeline_ctrl.v \
    hardware/rtl/core/spu13/spu13_core.v \
    hardware/rtl/core/spu13/spu13_irotc_engine.v \
    hardware/rtl/core/shared/spu_rotor_vault.v \
    hardware/rtl/core/shared/spu_cross_rotor.v \
    hardware/rtl/core/shared/davis_gate_dsp.v \
    hardware/rtl/core/shared/toroidal_regfile.v \
    hardware/rtl/core/shared/toroidal_regfile_ecc.v \
    hardware/rtl/math/rational_surd5_add.v \
    hardware/rtl/math/rational_surd5_mul.v \
    hardware/rtl/math/rational_surd5_mul64.v \
    hardware/rtl/math/rational_surd5_norm.v \
    hardware/rtl/math/rational_surd5_scale_manager.v \
    hardware/rtl/common/prim/spu_gowin_prim.v \
    hardware/rtl/common/prim/gowin_mult18.v \
    hardware/rtl/core/spu13/spu13_rotor_core_tdm.v \
    hardware/rtl/core/shared/spu_quadray_permute.v \
    hardware/rtl/core/shared/spu_quadray_regfile.v \
    hardware/rtl/common/prim/spu_hamming_72_64.v \
    hardware/rtl/core/shared/spu_quadray_regfile_ecc.v \
    hardware/rtl/top/spu_ve_qr_init.v \
    hardware/rtl/common/prim/surd_multiplier.v \
    hardware/rtl/core/spu13/spu_quadrance_accum.v \
    hardware/rtl/core/spu13/rplu_pipeline.v \
    hardware/rtl/core/spu13/spu_som_weight_bram.v \
    hardware/rtl/core/spu13/spu_som_bmu.v \
    hardware/rtl/core/spu13/spu13_btu_core_top.v \
    hardware/rtl/core/spu13/spu_btu_collision_resolver.v \
    hardware/rtl/core/spu13/spu_bram_32x64_array.v \
    hardware/rtl/gpu/rplu_thimble_pade.v \
    hardware/rtl/core/spu13/spu13_quadray_variety.v \
    hardware/rtl/core/spu13/spu13_m31_multiplier.v \
    hardware/rtl/core/spu13/spu13_fp4_inverter.v \
    hardware/rtl/core/spu13/spu13_m31_inverter.v \
    hardware/rtl/core/spu13/spu13_nsa_core.v \
    hardware/rtl/core/spu13/spu13_nsa_dual_alu.v \
    hardware/rtl/core/spu13/spu13_nsa_regfile_wrapper.v \
    hardware/rtl/core/spu13/spu13_topology6_state.v \
    hardware/rtl/core/spu13/spu13_janus_dual_mode.v \
    hardware/rtl/core/spu13/spu13_janus_screw_lines.v \
    hardware/rtl/core/spu13/spu13_janus_mirror.v \
    hardware/rtl/arch/spu_optional_stubs.v

chparam -set CORE_ENABLE_MATH 0 \
        -set CORE_ENABLE_IROTC 1 \
        spu13_tang25k_southbridge_top

hierarchy -top spu13_tang25k_southbridge_top
synth_gowin -family gw5a -top spu13_tang25k_southbridge_top \
    -json build/spu13_irotc_spi.json -run begin:map_cells
techmap -map +/gowin/cells_map.v
opt_lut_ins -tech gowin
hilomap -singleton -hicell VCC V -locell GND G
clean
hierarchy -check
check -noinit
blackbox =A:whitebox
write_json build/spu13_irotc_spi.json
