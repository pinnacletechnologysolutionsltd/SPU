# synth_gowin_25k_spu13_satellite_aggregator_probe.ys
# 13-satellite whisper aggregator probe for Tang Primer 25K.
# Verified in testbench:
#   hardware/tests/spu13/spu13_satellite_aggregator_tb.v (module)
#   hardware/tests/spu13/spu13_tang25k_satellite_aggregator_probe_tb.v (this top)

read_verilog -lib +/gowin/cells_xtra_gw5a.v

read_verilog -I hardware/rtl/arch \
    hardware/rtl/peripherals/whisper/spu_uart_tx.v \
    hardware/rtl/peripherals/whisper/spu_uart_rx.v \
    hardware/rtl/peripherals/whisper/spu_whisper_v1_emitter.v \
    hardware/rtl/peripherals/whisper/spu_whisper_v1_listener.v \
    hardware/rtl/core/spu13/spu13_satellite_aggregator.v \
    hardware/boards/tang_primer_25k/spu13_tang25k_satellite_aggregator_probe.v

hierarchy -top spu13_tang25k_satellite_aggregator_probe

synth_gowin -family gw5a -top spu13_tang25k_satellite_aggregator_probe \
    -json build/tang_primer_25k_satellite_aggregator_probe.json -run begin:map_cells
techmap -map +/gowin/cells_map.v
opt_lut_ins -tech gowin
hilomap -singleton -hicell VCC V -locell GND G
clean
hierarchy -check
check -noinit
blackbox =A:whitebox
write_json build/tang_primer_25k_satellite_aggregator_probe.json
