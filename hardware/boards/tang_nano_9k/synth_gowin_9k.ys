# synth_gowin_9k.ys — Yosys synthesis script for Tang Nano 9K (GW1N-9C)
# Open-source flow: yosys → nextpnr-himbaechel → gowin_pack
#
# Prerequisites:
#   yosys             >= 0.38  (with synth_gowin support)
#   nextpnr-himbaechel (from oss-cad-suite)
#   gowin_pack         (from oss-cad-suite)
#
# Usage:
#   yosys hardware/boards/tang_nano_9k/synth_gowin_9k.ys
#   nextpnr-himbaechel --device GW1N-9C-QN88-I6/I5 \
#       --chipdb ~/.oss-cad-suite/share/nextpnr/himbaechel/gowin/chipdb-GW1N-9C.bin \
#       --json build/tang_nano_9k.json \
#       --cst  hardware/boards/tang_nano_9k/tang_nano_9k.cst \
#       --write build/tang_nano_9k_pnr.json --freq 24
#   gowin_pack build/tang_nano_9k_pnr.json -o build/tang_nano_9k.fs
#   openFPGALoader -b tangnano9k build/tang_nano_9k.fs
#
# GW1N-9C resources: 8640 LUT4, 6480 FF, 26×18 Kb BSRAM, 20 DSP18
#   SPU-4 core uses ~16 DSPs → fits with 4 spare.
#   SPU-13 Cortex requires 52 DSPs → does NOT fit; use Tang 20K/25K for SPU-13.

# ─── Source files ──────────────────────────────────────────────────────────

read_verilog -sv -I hardware/common/rtl hardware/common/rtl/spu_arch_defines.vh

# Gowin vendor primitives (MULT18X18, BSRAM, Gowin-specific ALU)
read_verilog -I hardware/common/rtl hardware/vendor/gowin/gowin_bsram.v
read_verilog -I hardware/common/rtl hardware/vendor/gowin/spu_alu_gowin.v
read_verilog -I hardware/common/rtl hardware/vendor/gowin/spu_surd_mul_gowin.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/gowin_mult18.v

# Primitives
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_multiplier_serial.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_psram_ctrl.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_smul_tdm.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/spu_laminar_fold.v
read_verilog -I hardware/common/rtl hardware/common/rtl/prim/surd_multiplier.v

# Core utilities
read_verilog -I hardware/common/rtl hardware/common/rtl/spu_register_file.v
read_verilog -I hardware/common/rtl hardware/common/rtl/spu_cross_rotor.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/davis_gate_dsp.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu_rotor_vault.v
read_verilog -I hardware/common/rtl hardware/common/rtl/core/spu13_sequencer.v

# Memory
read_verilog -I hardware/common/rtl hardware/common/rtl/mem/spu_fractal_compressor.v

# Top-level subsystems
read_verilog -I hardware/common/rtl hardware/common/rtl/top/spu_sierpinski_clk.v
read_verilog -I hardware/common/rtl hardware/common/rtl/spu_soft_start.v
read_verilog -I hardware/common/rtl hardware/common/rtl/top/spu_laminar_power.v

# Protocol
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/SPU_WHISPER_TX.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/SPU_WHISPER_RX.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/SPU_ARTERY_FIFO.v
read_verilog -I hardware/common/rtl hardware/common/rtl/proto/spu_node_link.v

# SPU-4 core (uses Gowin DSP18 blocks — 16 of 20 available on GW1N-9C)
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_sovereign_bus.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_dream_sequencer.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_boot_master.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_decoder.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu_4_euclidean_alu.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_regfile.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_core.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu4_top.v

# Janus (SPU-4 stability checks) + satellite kernel
read_verilog -I hardware/common/rtl hardware/spu13/rtl/spu_janus_mirror.v
read_verilog -I hardware/common/rtl hardware/spu4/rtl/spu_4_satellite.v

# Board top
read_verilog -I hardware/common/rtl hardware/boards/tang_nano_9k/tang_nano_9k_top.v

# ─── Synthesis ─────────────────────────────────────────────────────────────

synth_gowin -family gw1n -top tang_nano_9k_top -json build/tang_nano_9k.json

# ─── Reporting ─────────────────────────────────────────────────────────────
stat
