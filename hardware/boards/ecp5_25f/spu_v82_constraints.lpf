# SPU Sovereign Cluster - Colorlight 5A-75B V8.2 Constraints
# Based on chubby75 hardware_V8.2.md
# Target: LFE5U-25F-6BG256C

# --- Clock (25 MHz from PHY1) ---
LOCATE COMP "clk_25" SITE "P6";
IOBUF PORT "clk_25" IO_TYPE=LVCMOS33;

# --- Heartbeat LED (Active Low) ---
LOCATE COMP "led_heartbeat" SITE "T6";
IOBUF PORT "led_heartbeat" IO_TYPE=LVCMOS33;

# --- UART (J1 Header - Optional Mapping) ---
# Using J1-R0 and J1-G0 for UART if buffers are bypassed, 
# but for now we'll stick to serial-over-Eth or JTAG-Serial.
# Pins C4, D4 are HUB75 buffered outputs usually.

# --- Internal SPI Flash (via USRMCLK) ---
LOCATE COMP "flash_cs_n" SITE "N8";
IOBUF PORT "flash_cs_n" IO_TYPE=LVCMOS33;
LOCATE COMP "flash_mosi" SITE "T8";
IOBUF PORT "flash_mosi" IO_TYPE=LVCMOS33;
LOCATE COMP "flash_miso" SITE "T7";
IOBUF PORT "flash_miso" IO_TYPE=LVCMOS33;
# flash_sclk is handled by USRMCLK primitive in spu_flash_bridge.v

# --- SD Card PMOD (on JTAG Header pins) ---
# TCK=J27, TMS=J31, TDI=J32, TDO=J30
# Note: These are dedicated pins, nextpnr handles them specially 
# if defined as GPIO post-config.
LOCATE COMP "sd_sck" SITE "J27"; # TCK
LOCATE COMP "sd_cs"  SITE "J31"; # TMS
LOCATE COMP "sd_mosi" SITE "J32"; # TDI
LOCATE COMP "sd_miso" SITE "J30"; # TDO
IOBUF PORT "sd_sck" IO_TYPE=LVCMOS33;
IOBUF PORT "sd_cs"  IO_TYPE=LVCMOS33;
IOBUF PORT "sd_mosi" IO_TYPE=LVCMOS33;
IOBUF PORT "sd_miso" IO_TYPE=LVCMOS33;

# --- Onboard SDRAM (ESMT M12L64322A - 32-bit) ---
LOCATE COMP "sdram_clk" SITE "C8";
IOBUF PORT "sdram_clk" IO_TYPE=LVCMOS33;

LOCATE COMP "sdram_ras_n" SITE "B6";
LOCATE COMP "sdram_cas_n" SITE "A6";
LOCATE COMP "sdram_we_n"  SITE "B5";
IOBUF PORT "sdram_ras_n" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_cas_n" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_we_n"  IO_TYPE=LVCMOS33;

LOCATE COMP "sdram_ba[0]" SITE "B7";
LOCATE COMP "sdram_ba[1]" SITE "A8";
IOBUF PORT "sdram_ba[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_ba[1]" IO_TYPE=LVCMOS33;

LOCATE COMP "sdram_addr[0]" SITE "A9";
LOCATE COMP "sdram_addr[1]" SITE "B9";
LOCATE COMP "sdram_addr[2]" SITE "B10";
LOCATE COMP "sdram_addr[3]" SITE "C10";
LOCATE COMP "sdram_addr[4]" SITE "D9";
LOCATE COMP "sdram_addr[5]" SITE "C9";
LOCATE COMP "sdram_addr[6]" SITE "E9";
LOCATE COMP "sdram_addr[7]" SITE "D8";
LOCATE COMP "sdram_addr[8]" SITE "E8";
LOCATE COMP "sdram_addr[9]" SITE "C7";
LOCATE COMP "sdram_addr[10]" SITE "B8"; # A10/AP
IOBUF PORT "sdram_addr[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[4]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[5]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[6]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[7]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[8]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[9]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_addr[10]" IO_TYPE=LVCMOS33;

# DQ Data Bus [0:15]
LOCATE COMP "sdram_dq[0]" SITE "B2";
LOCATE COMP "sdram_dq[1]" SITE "A2";
LOCATE COMP "sdram_dq[2]" SITE "C3";
LOCATE COMP "sdram_dq[3]" SITE "A3";
LOCATE COMP "sdram_dq[4]" SITE "B3";
LOCATE COMP "sdram_dq[5]" SITE "A4";
LOCATE COMP "sdram_dq[6]" SITE "B4";
LOCATE COMP "sdram_dq[7]" SITE "A5";
LOCATE COMP "sdram_dq[8]" SITE "E7";
LOCATE COMP "sdram_dq[9]" SITE "C6";
LOCATE COMP "sdram_dq[10]" SITE "D7";
LOCATE COMP "sdram_dq[11]" SITE "D6";
LOCATE COMP "sdram_dq[12]" SITE "E6";
LOCATE COMP "sdram_dq[13]" SITE "D5";
LOCATE COMP "sdram_dq[14]" SITE "C5";
LOCATE COMP "sdram_dq[15]" SITE "E5";
# DQ Data Bus [16:31]
LOCATE COMP "sdram_dq[16]" SITE "A11";
LOCATE COMP "sdram_dq[17]" SITE "B11";
LOCATE COMP "sdram_dq[18]" SITE "B12";
LOCATE COMP "sdram_dq[19]" SITE "A13";
LOCATE COMP "sdram_dq[20]" SITE "B13";
LOCATE COMP "sdram_dq[21]" SITE "A14";
LOCATE COMP "sdram_dq[22]" SITE "B14";
LOCATE COMP "sdram_dq[23]" SITE "D14";
LOCATE COMP "sdram_dq[24]" SITE "D13";
LOCATE COMP "sdram_dq[25]" SITE "E11";
LOCATE COMP "sdram_dq[26]" SITE "C13";
LOCATE COMP "sdram_dq[27]" SITE "D11";
LOCATE COMP "sdram_dq[28]" SITE "C12";
LOCATE COMP "sdram_dq[29]" SITE "E10";
LOCATE COMP "sdram_dq[30]" SITE "C11";
LOCATE COMP "sdram_dq[31]" SITE "D10";

IOBUF PORT "sdram_dq[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[4]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[5]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[6]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[7]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[8]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[9]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[10]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[11]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[12]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[13]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[14]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[15]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[16]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[17]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[18]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[19]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[20]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[21]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[22]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[23]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[24]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[25]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[26]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[27]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[28]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[29]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[30]" IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[31]" IO_TYPE=LVCMOS33;

# --- Ethernet PHYs (Dual Gigabit) ---
# PHY1 (U13) Clock is P6
LOCATE COMP "eth0_txc" SITE "L1";
LOCATE COMP "eth0_tx_ctl" SITE "L2";
LOCATE COMP "eth0_txd[0]" SITE "M2";
LOCATE COMP "eth0_txd[1]" SITE "M1";
LOCATE COMP "eth0_txd[2]" SITE "P1";
LOCATE COMP "eth0_txd[3]" SITE "R1";
LOCATE COMP "eth0_rxc" SITE "J1";
LOCATE COMP "eth0_rx_ctl" SITE "J2";
LOCATE COMP "eth0_rxd[0]" SITE "K2";
LOCATE COMP "eth0_rxd[1]" SITE "J3";
LOCATE COMP "eth0_rxd[2]" SITE "K1";
LOCATE COMP "eth0_rxd[3]" SITE "K3";

IOBUF PORT "eth0_txc" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_tx_ctl" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_txd[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_txd[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_txd[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_txd[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rxc" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rx_ctl" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rxd[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rxd[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rxd[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "eth0_rxd[3]" IO_TYPE=LVCMOS33;
