// spu_ecp5_industrial.lpf — Colorlight 5A-75B v8.2 Industrial Pin Constraints
// Objective: Map the 56 HUB75 pins for high-density motion control.

# --- Global Control Pins (Shared across all 8 Hubs) ---
LOCATE COMP "hub_clk" SITE "L2";
LOCATE COMP "hub_lat" SITE "K2";
LOCATE COMP "hub_oe"  SITE "J2";
LOCATE COMP "hub_a"   SITE "I2";
LOCATE COMP "hub_b"   SITE "I1";
LOCATE COMP "hub_c"   SITE "J3";
LOCATE COMP "hub_d"   SITE "K3";
LOCATE COMP "hub_e"   SITE "M3";

IOBUF PORT "hub_clk" IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_lat" IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_oe"  IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_a"   IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_b"   IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_c"   IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_d"   IO_TYPE=LVCMOS33 SLEWRATE=FAST;
IOBUF PORT "hub_e"   IO_TYPE=LVCMOS33 SLEWRATE=FAST;

# --- RGB Data Pins (Individual per Hub J1-J8) ---

# J1
LOCATE COMP "hub_j1[0]" SITE "F2"; # R1
LOCATE COMP "hub_j1[1]" SITE "G1"; # G1
LOCATE COMP "hub_j1[2]" SITE "H2"; # B1
LOCATE COMP "hub_j1[3]" SITE "G2"; # R2
LOCATE COMP "hub_j1[4]" SITE "K1"; # G2
LOCATE COMP "hub_j1[5]" SITE "J1"; # B2

# J2
LOCATE COMP "hub_j2[0]" SITE "B1"; # R1
LOCATE COMP "hub_j2[1]" SITE "C2"; # G1
LOCATE COMP "hub_j2[2]" SITE "C1"; # B1
LOCATE COMP "hub_j2[3]" SITE "D2"; # R2
LOCATE COMP "hub_j2[4]" SITE "E2"; # G2
LOCATE COMP "hub_j2[5]" SITE "E1"; # B2

# J3
LOCATE COMP "hub_j3[0]" SITE "P1"; # R1
LOCATE COMP "hub_j3[1]" SITE "N1"; # G1
LOCATE COMP "hub_j3[2]" SITE "M1"; # B1
LOCATE COMP "hub_j3[3]" SITE "P2"; # R2
LOCATE COMP "hub_j3[4]" SITE "R1"; # G2
LOCATE COMP "hub_j3[5]" SITE "R2"; # B2

# J4
LOCATE COMP "hub_j4[0]" SITE "T1"; # R1
LOCATE COMP "hub_j4[1]" SITE "Y2"; # G1
LOCATE COMP "hub_j4[2]" SITE "W2"; # B1
LOCATE COMP "hub_j4[3]" SITE "V2"; # R2
LOCATE COMP "hub_j4[4]" SITE "V1"; # G2
LOCATE COMP "hub_j4[5]" SITE "U2"; # B2

# J5
LOCATE COMP "hub_j5[0]" SITE "B11"; # R1
LOCATE COMP "hub_j5[1]" SITE "D11"; # G1
LOCATE COMP "hub_j5[2]" SITE "C11"; # B1
LOCATE COMP "hub_j5[3]" SITE "E11"; # R2
LOCATE COMP "hub_j5[4]" SITE "F11"; # G2
LOCATE COMP "hub_j5[5]" SITE "A11"; # B2

# J6
LOCATE COMP "hub_j6[0]" SITE "B10"; # R1
LOCATE COMP "hub_j6[1]" SITE "C10"; # G1
LOCATE COMP "hub_j6[2]" SITE "D10"; # B1
LOCATE COMP "hub_j6[3]" SITE "E10"; # R2
LOCATE COMP "hub_j6[4]" SITE "F10"; # G2
LOCATE COMP "hub_j6[5]" SITE "A10"; # B2

# J7
LOCATE COMP "hub_j7[0]" SITE "B9";  # R1
LOCATE COMP "hub_j7[1]" SITE "C9";  # G1
LOCATE COMP "hub_j7[2]" SITE "D9";  # B1
LOCATE COMP "hub_j7[3]" SITE "E9";  # R2
LOCATE COMP "hub_j7[4]" SITE "F9";  # G2
LOCATE COMP "hub_j7[5]" SITE "A9";  # B2

# J8
LOCATE COMP "hub_j8[0]" SITE "B8";  # R1
LOCATE COMP "hub_j8[1]" SITE "C8";  # G1
LOCATE COMP "hub_j8[2]" SITE "D8";  # B1
LOCATE COMP "hub_j8[3]" SITE "E8";  # R2
LOCATE COMP "hub_j8[4]" SITE "F8";  # G2
LOCATE COMP "hub_j8[5]" SITE "A8";  # B2

# --- JTAG / PMOD Header (Hybrid Sensor Interface) ---
LOCATE COMP "jtag_tck" SITE "F14";
LOCATE COMP "jtag_tms" SITE "E14";
LOCATE COMP "jtag_tdi" SITE "D15";
LOCATE COMP "jtag_tdo" SITE "E15";

IOBUF PORT "jtag_tck" IO_TYPE=LVCMOS33 PULLMODE=UP;
IOBUF PORT "jtag_tms" IO_TYPE=LVCMOS33 PULLMODE=UP;
IOBUF PORT "jtag_tdi" IO_TYPE=LVCMOS33 PULLMODE=UP;
IOBUF PORT "jtag_tdo" IO_TYPE=LVCMOS33 PULLMODE=UP;

# Setting all HUB75 pins as outputs with 3.3V LVCMOS
