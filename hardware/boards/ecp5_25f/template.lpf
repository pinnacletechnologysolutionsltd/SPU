# template.lpf — Lattice ECP5-25F pinout template
# Target: LFE5U-25F-6BG256C

BLOCK RESETPATHS ;
BLOCK ASYNCPATHS ;

# --- Primary Clock (Example: 25 MHz or 50 MHz) ---
# LOCATE COMP "clk" SITE "A10";  # Update with your board's clock pin
# IOBUF PORT "clk" IO_TYPE=LVCMOS33 ;
# FREQUENCY PORT "clk" 25.0 MHz ;

# --- Primary Reset ---
# LOCATE COMP "rst_n" SITE "B10"; # Update with your board's reset pin
# IOBUF PORT "rst_n" IO_TYPE=LVCMOS33 ;

# --- Status LEDs ---
# LOCATE COMP "led[0]" SITE "C1";
# LOCATE COMP "led[1]" SITE "C2";
# LOCATE COMP "led[2]" SITE "C3";
# LOCATE COMP "led[3]" SITE "C4";
# LOCATE COMP "led[4]" SITE "C5";
# LOCATE COMP "led[5]" SITE "C6";
# LOCATE COMP "led[6]" SITE "C7";
# LOCATE COMP "led[7]" SITE "C8";
# IOBUF PORT "led[0]" IO_TYPE=LVCMOS33 ;
# IOBUF PORT "led[1]" IO_TYPE=LVCMOS33 ;
# IOBUF PORT "led[2]" IO_TYPE=LVCMOS33 ;
# ...

