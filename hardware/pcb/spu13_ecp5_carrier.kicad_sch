	)
	(text "Open toolchain: yosys + nextpnr-ecp5 + KiCad 10 | CERN-OHL-W-2.0" (at 10 185 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "POWER RAILS (all MLCC decoupling per hardware/docs/power_tree.md):" (at 10 180 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_CORE: 1.1V @ 1.5A (TPS62082 buck) - 2x22uF + 2x4.7uF + 8x100nF" (at 10 175 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_IO:   3.3V @ 500mA (AP2112K-3.3 LDO) - 1x22uF + 1x4.7uF + 4x100nF" (at 10 170 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_1V8:  1.8V @ 200mA (TPS62232 buck) - 1x10uF + 1x4.7uF + 2x100nF" (at 10 165 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_PLL:  2.5V @ 50mA (LP5907-2.5 LDO) - BLM18PG221 + 4.7uF + 100nF" (at 10 160 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_BATT: 3.0V (CR2032 diode-OR) - standby only" (at 10 155 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  VCC_FLASH/SD: 3.3V rail - independent LDO or shared AP2112K" (at 10 150 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "SPI SOUTHBRIDGE BUS (RP2350 -> ECP5, Bank 3 @ 3.3V):" (at 10 135 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  CS#  = RP2350 GP1  -> ECP5 Bank3 GPIO (EE: assign ball from CABGA381 datasheet)" (at 10 130 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  SCK  = RP2350 GP2  -> ECP5 Bank3 GPIO (use clock-capable input)" (at 10 125 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  MOSI = RP2350 GP3  -> ECP5 Bank3 GPIO" (at 10 120 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  MISO = RP2350 GP0  <- ECP5 Bank3 GPIO" (at 10 115 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  Mode 0 CPOL=0 CPHA=0 2MHz/12MHz | Series R=22 SCK/MOSI near RP2350, 33 near FPGA" (at 10 110 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  CS# pull-up 10k to 3.3V | See hardware/docs/ecp5_oshwa_carrier_spec.md for full spec" (at 10 105 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "PIO PARALLEL BUS (RP2350 -> ECP5 Bank 4 @ 3.3V, 8-bit half-duplex):" (at 10 90 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  DATA[7:0] = RP2350 GP4-9,14-15 -> ECP5 Bank4 (contiguous; EE assigns balls)" (at 10 85 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  STROBE    = RP2350 GP16 -> ECP5 Bank4" (at 10 80 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  READY     = RP2350 GP17 <- ECP5 Bank4" (at 10 75 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  DIR/WE    = RP2350 GP18 -> ECP5 Bank4 (1=FPGA drives bus)" (at 10 70 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  Series R=22 on DATA/STB/DIR near RP2350 | Matched skew <0.5ns" (at 10 65 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  GND guard traces between lanes | See spec for full timing budget" (at 10 60 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "MICROSD (RP2350 SPI1):" (at 10 45 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  CS#  = RP2350 GP13 -> microSD DAT3" (at 10 40 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  SCK  = RP2350 GP10 -> microSD CLK" (at 10 35 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  MOSI = RP2350 GP11 -> microSD CMD" (at 10 30 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  MISO = RP2350 GP12 <- microSD DAT0" (at 10 25 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  400kHz init, 8MHz post-init. Pullups on CMD/DAT3/CS#." (at 10 20 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "ECP5 CONFIG: MODE[2:0]=001 (master SPI from W25Q128). PROGRAM# pulled high + RP2350 override." (at 10 8 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  DONE + INIT# pulled high with LEDs | Slave-SPI config path via separate RP2350 GPIO" (at 10 3 0)
		(effects (font (size 1.27 1.27) (thickness 0.15)))
	)
	(text "  RP2350 PIO bit-bangs JTAG: TCK/TDI/TDO/TMS on Bank5 (same pinout as DirtyJTAG)" (at 10 -2 0)
